{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=Wallet2;Integrated Security=True;Connect Timeout=30;Encrypt=False;TrustServerCertificate=False;"
  },
  "UseEfCore": false,
  "Jwt": {
    "Issuer": "MyWallet.AuthAPI",
    "Audience": "MyWallet.Clients",
    "Key": "your-super-secret-jwt-key-minimum-32-characters-long-12345",
    "ExpireMinutes": 30,
    "RefreshTokenExpireDays": 7
  },

  "ApiKey": "your_secure_api_key_here_change_in_production_12345",

  "Security": {
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 30,
    "PasswordPolicy": {
      "MinLength": 8,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireSpecialCharacter": true
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
